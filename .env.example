# Required for all deployments
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# --- Supabase (required) — user sign-in and per-user Canvas tokens ---
# From Supabase Dashboard: Project Settings, API (Project URL + anon/publishable key).
# After editing .env.local you MUST restart the dev server: stop npm run dev, then run again.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — used to create signup confirmation links (never expose to the browser).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Brevo (required for sign-up) — confirmation emails ---
# Create an API key at https://app.brevo.com/settings/keys/api
# Verify your sender under Senders & IPs before sending.
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=noreply@yourdomain.com
# BREVO_SENDER_NAME=CanvasBuddy

# --- OAuth (optional) — for "Sign in with Canvas" at your school ---
# Only needed if your school hosts CanvasBuddy with a developer key.
# Students can use a personal access token in Settings instead.

# CANVAS_BASE_URL=https://yourschool.instructure.com
# CANVAS_CLIENT_ID=
# CANVAS_CLIENT_SECRET=
# CANVAS_REDIRECT_URI=http://localhost:3000/api/auth/canvas/callback

# OAuth scopes (space-separated). Leave unset if your key uses legacy full access.
# CANVAS_SCOPES=url:GET|/api/v1/courses url:GET|/api/v1/planner/items url:GET|/api/v1/users/self url:GET|/api/v1/courses/:course_id/assignments

# Optional: default timezone for "tomorrow" when the browser does not send one
# TZ=America/New_York

# --- Assignment assistant (Claude / Anthropic) ---
# Required for the AI assistant that answers questions about assignments.
# ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
